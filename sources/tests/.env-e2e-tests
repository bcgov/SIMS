# This file is intended to override some values from the global .env file
# and it must not contain any sensitive information.

BUILD_REF=tests
SWAGGER_ENABLED=false

# Database
POSTGRES_DB=aest_e2e_tests
POSTGRES_USER=admin_e2e_tests
POSTGRES_PASSWORD=aest_sim_e2e_tests
POSTGRES_PORT=5430
DISABLE_ORM_CACHE=true
# bypass override
BYPASS_APPLICATION_SUBMIT_VALIDATIONS=true

# Form.io
# Credentials match the ROOT_EMAIL/ROOT_PASSWORD set in the test Form.io container.
FORMS_SA_USER_NAME=admin@example.com
FORMS_SA_PASSWORD=CHANGEME

# Zeebe
CAMUNDA_OAUTH_DISABLED=true
# Versions used by camunda-docker-compose-core.yml during the make camunda.
CAMUNDA_PLATFORM_VERSION=8.7.12