{
    "title": "Non-punitive Withdrawal",
    "name": "nonpunitivewithdrawalform",
    "path": "nonpunitivewithdrawalform",
    "type": "form",
    "display": "form",
    "tags": [
        "common"
    ],
    "components": [
        {
            "label": "Withdrawal Scholastic Standing Applications",
            "key": "scholasticStandingWithdrawals",
            "tags": [
                "supplementary-data"
            ],
            "type": "hidden",
            "input": true,
            "tableView": false
        },
        {
            "label": "HTML",
            "tag": "h3",
            "className": "category-header-medium primary-color",
            "attrs": [
                {
                    "attr": "",
                    "value": ""
                }
            ],
            "content": "This form is used to reverse the eligibility impacts of a withdrawal when certain criteria have been met.",
            "refreshOnChange": false,
            "key": "html",
            "type": "htmlelement",
            "input": false,
            "tableView": false
        },
        {
            "label": "Application",
            "widget": "choicesjs",
            "placeholder": "Application Number",
            "customClass": "font-weight-bold",
            "tableView": true,
            "customOptions": "",
            "validateWhenHidden": false,
            "key": "select",
            "logic": [
                {
                    "name": "Populate application number list",
                    "trigger": {
                        "type": "javascript",
                        "javascript": "result = !!data.scholasticStandingWithdrawals;"
                    },
                    "actions": [
                        {
                            "name": "Populate application number dropdown",
                            "type": "customAction",
                            "customAction": "component.data.values = data.scholasticStandingWithdrawals.map((withdrawal) => ({\r\n  value: withdrawal.scholasticStandingId,\r\n  label: withdrawal.applicationNumber,\r\n}));"
                        }
                    ]
                }
            ],
            "type": "select",
            "input": true
        },
        {
            "label": "Please indicate which of the following circumstances applies to you.",
            "optionsLabelPosition": "right",
            "tableView": false,
            "defaultValue": {
                "didNotAttendClasses": false,
                "attendedClassesFor10DaysOrLess": false,
                "completedFirstSemester": false,
                "withdrawnFromStudies": false,
                "noneOfTheAbove": false
            },
            "values": [
                {
                    "label": " I did not attend classes at all and repaid the funding in full within 30 days of the start of classes",
                    "value": "didNotAttendClasses",
                    "shortcut": ""
                },
                {
                    "label": "I attended classes for 10 days or less and repaid the funding in full within 30 days of the start of classes",
                    "value": "attendedClassesFor10DaysOrLess",
                    "shortcut": ""
                },
                {
                    "label": "I completed my first semester, including exams (if applicable), and either did not return to my studies or attended for 10 days or less in the next semester. The funding for the second semester was either not issued to me or it was and repaid in full within 30 days of the start of classes.",
                    "value": "completedFirstSemester",
                    "shortcut": ""
                },
                {
                    "label": "I was withdrawn from my studies as the result of an institution closure",
                    "value": "withdrawnFromStudies",
                    "shortcut": ""
                },
                {
                    "label": "None of the above",
                    "value": "noneOfTheAbove",
                    "shortcut": ""
                }
            ],
            "validate": {
                "custom": "const shouldSelectOneOfTheAboveOrAnotherOption =\r\n  (data.eligibleCircumstances.didNotAttendClasses ||\r\n    data.eligibleCircumstances.attendedClassesFor10DaysOrLess ||\r\n    data.eligibleCircumstances.completedFirstSemester ||\r\n    data.eligibleCircumstances.withdrawnFromStudies) &&\r\n  data.eligibleCircumstances.noneOfTheAbove;\r\n\r\nvalid = shouldSelectOneOfTheAboveOrAnotherOption\r\n  ? \"Please select at least one of the circumstances or 'None of the above'.\"\r\n  : true;"
            },
            "validateWhenHidden": false,
            "key": "eligibleCircumstances",
            "type": "selectboxes",
            "input": true,
            "inputType": "checkbox"
        },
        {
            "label": "Eligible Circumstances Banner",
            "tag": "p",
            "className": "alert alert-danger fa fa-ban w-100",
            "attrs": [
                {
                    "attr": "",
                    "value": ""
                }
            ],
            "content": "<strong> A non-punitive change to the study period end date may only be processed if one of the conditions above is met.\r\nIf none of the conditions apply, then the withdrawal is not eligible to be changed to non-punitive status. </strong>",
            "refreshOnChange": false,
            "key": "html1",
            "customConditional": "show = !!data.eligibleCircumstances.noneOfTheAbove;",
            "type": "htmlelement",
            "input": false,
            "tableView": false
        }
    ]
}