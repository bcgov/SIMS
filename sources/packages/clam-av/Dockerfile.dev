# Development version set to use a different version from PROD
# since the PROD version is no longer available on DockerHub.
FROM clamav/clamav:1.5.2
RUN freshclam
# Copy the clamd.conf file into the container
COPY clam-av/clamd.conf /etc/clamav/clamd.conf
COPY "clam-av/scripts/docker-entrypoint-unprivileged.sh" "/init"
RUN chmod +x /init