# Required
# OpenShift service account token with permission to read workloads/image streams
# and delete imagestreamtags in the tools namespace.
# Example: sha256~yourServiceAccountToken
SA_TOKEN=

# OpenShift API base URL (no trailing slash preferred).
# Example: https://api.gold.devops.gov.bc.ca:6443
OPENSHIFT_URL=

# License plate used to compose namespaces.
# Example: a1b2c3
LICENSE_PLATE=
