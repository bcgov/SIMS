# Required
# OpenShift service account token with permission to read workloads/image streams
# and delete imagestreamtags in the tools namespace.
# Example: sha256~yourServiceAccountToken
SA_TOKEN=

# OpenShift API base URL (no trailing slash preferred).
# Example: https://api.gold.devops.gov.bc.ca:6443
OPENSHIFT_URL=

# License plate used to compose namespaces.
# Example: a1b2c3
LICENSE_PLATE=

# Target environment. Allowed values: dev, test, prod.
# Example: dev
ENVIRONMENT=

# Optional
# Comma-separated deployment-backed application names (ImageStream names).
# Example: api-sims,queue-consumers-sims,workers-sims
APPLICATIONS=

# Comma-separated job-backed application names (job suffixes).
# Example: migrations-job
OCJOBS=

# Prefix for build tags, like main-12345.
# Example: main
PREFIX=

# Keep at least this many prefix tags per ImageStream.
# Example: 2
MIN_TAGS=
